@model ESIntegrateSys.Models.ES_MaterialGunInfo

@{
    ViewBag.Title = "料槍報廢作業";
}

<h2>Discard</h2>
<head>
    <script src="~/Scripts/jquery-3.4.1.min.js"></script>
    <link href="~/Content/bootstrap.css" rel="stylesheet" />
    <script>
        $(document).ready(function () {
            $.ajax({
                url: '@Url.Action("DiscardDesc", "MaterialGun")',
                type: 'GET',
                dataType: 'json',
                success: function (data) {
                    // 清空原有的選項
                    $('#DiscardDescription').empty();
                    // 在選擇器中動態添加選項
                    $.each(data, function (index, item) {
                        $('#DiscardDescription').append($('<option>', {
                            value: item.Value,
                            text: item.Text
                        }));
                    });
                },
                error: function (xhr, status, error) {
                    console.log('Ajax request failed. Status:', status);
                    console.log('Error:', error);
                    console.log('XHR object:', xhr);
                    alert('Ajax request failed. Status: ' + status + '\nError: ' + error);
                }
            });
        });

        $(document).ready(function () {
            $("input[type='submit']").click(function (e) {
                if (!$("input[name='isTrue']").is(":checked")) {
                    e.preventDefault(); // 阻止表單提交
                    alert("請先勾選保養項目");
                }
                var selectedValue = $("#DiscardDescription").val();
                if (selectedValue == 0) {
                    e.preventDefault(); // 阻止表單提交
                    alert("請選擇報廢原因");
                }
            });
        });

    </script>
</head>
@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()
    
<div class="form-horizontal">
    <h4>料槍報廢作業</h4>
    <hr />
    @Html.ValidationSummary(true, "", new { @class = "text-danger" })
    @Html.HiddenFor(model => model.sno)

    <div class="form-group">
        <label class="control-label col-md-2"></label>
        <div class="col-md-10">
            <p>@Html.CheckBox("isTrue", false) 該料槍皆已執行相關確認動作</p>
        </div>
    </div>
    <div class="form-group">
        <label class="control-label col-md-2">料槍編號</label>
        <div class="col-md-10">
            <input class="form-control" id="MaterialGun_Sno" name="MaterialGun_Sno" value="@Html.DisplayFor(m=>m.MaterialGun_Sno)" disabled="disabled" />
        </div>
    </div>
    <div class="form-group">
        <label class="control-label col-md-2">報廢原因</label>
        <div class="col-md-10">
            <select id="DiscardDescription" name="DiscardDescription" class="form-control"></select>
        </div>
    </div>
    <div class="form-group">
        <label class="control-label col-md-2">備註</label>
        <div class="col-md-10">
            <input class="form-control" id="Mark" name="Mark" autocomplete="off" />
        </div>
    </div>
    <div class="form-group">
        <div class="col-md-offset-2 col-md-10">
            <input type="submit" value="確認報廢" class="btn btn-default" />
        </div>
    </div>
</div>
}

<div>
    <a href="javascript:history.go(-1);" class="btn btn-default">返回上一頁</a>
</div>
