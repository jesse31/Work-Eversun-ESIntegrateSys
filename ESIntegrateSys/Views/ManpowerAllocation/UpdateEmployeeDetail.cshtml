@model ESIntegrateSys.Models_ManpowerAllocation.人力配置明細異動Dto

@{
    ViewBag.Title = "編輯人員明細";
}

@*/** SweetAlert2 **********************************************************************************************************/*@
<script src="~/Scripts/sweetalert2.all.min.js"></script>

<!-- 引入 Bootstrap Icons 樣式表 -->
<link href="~/Content/bootstrap-icons/bootstrap-icons.css" rel="stylesheet" />


<div class="container-fluid">
    <div class="page-header">
        <h2>人力配置管理系統</h2>
        <ol class="breadcrumb">
            <li>
                <a href="@Url.Action("Index", "ManpowerAllocation")" class="btn btn-success">
                    <i class="bi bi-arrow-return-left"></i> 人力配置
                </a>
            </li>

        </ol>
    </div>
    <div class="col-md-12">
        <div class="panel panel-blue">
            <div class="panel-heading">
                <h3 class="panel-title">編輯人員明細</h3>
            </div>
            <div class="panel-body">
                <form id="editEmployeeForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="edit-employee-id" name="strPK" value="@Model.strPK" />
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="edit-reporting-unit" class="required-field">報工生產單位</label>
                                <select class="form-control" id="edit-reporting-unit" name="str報工生產單位名稱" required>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="edit-production-unit" class="required-field">生產單位名稱</label>
                                <select class="form-control" id="edit-production-unit" name="str生產單位名稱" required>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="edit-shift" class="required-field">班別名稱</label>
                                <select class="form-control" id="edit-shift" name="str班別名稱" required>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="edit-attendance-type" class="required-field">出勤類型</label>
                                <select class="form-control" id="edit-attendance-type" name="str出勤類型" required>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="edit-employee-no" class="required-field">作業人員工號</label>
                                <input type="text" class="form-control" id="edit-employee-no" name="str作業人員工號" value="@Model.str作業人員工號" required>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="edit-employee-name" class="required-field">作業人員姓名</label>
                                <input type="text" class="form-control" id="edit-employee-name" name="str作業人員姓名" value="@Model.str作業人員姓名" required>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group">
                                <label for="edit-remarks">備註</label>
                                <textarea class="form-control" id="edit-remarks" name="str備註" rows="5" style="width: 100% !important; max-width: 100% !important; display: block; resize:vertical;">@Model.str備註</textarea>
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-12 text-center">
                            <button type="button" class="btn btn-success" id="save-employee"><i class="bi bi-save"></i>儲存</button>
                            <button type="button" class="btn btn-danger" id="cancel-button"><i class="bi bi-x-circle"></i>取消</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script type="text/javascript">
        // 全局 AJAX 設定，處理未授權請求
        $.ajaxSetup({
            statusCode: {
                401: function() {
                    // 處理未授權狀態
                    Swal.fire({
                        icon: 'warning',
                        title: '登入過期',
                        text: '您的登入狀態已過期，請重新登入。',
                        confirmButtonText: '確定'
                    }).then(() => {
                        window.location.href = '@Url.Action("Login", "Home")?ReturnUrl=' + encodeURIComponent(window.location.href);
                    });
                },
                403: function() {
                    // 處理禁止訪問狀態
                    Swal.fire({
                        icon: 'error',
                        title: '拒絕存取',
                        text: '您沒有權限執行此操作。',
                        confirmButtonText: '確定'
                    }).then(() => {
                        window.location.href = '@Url.Action("Index", "Home")';
                    });
                }
            }
        });

        $(document).ready(function () {
            // 初始化下拉選單
            initDropdowns();

            // 儲存按鈕點擊事件
            $("#save-employee").click(function () {
                // 驗證表單
                if (!$("#editEmployeeForm")[0].checkValidity()) {
                    $("#editEmployeeForm")[0].reportValidity();
                    return;
                }

                // 獲取表單數據（修正：下拉選單傳送 key/value）
                var formData = {
                    __RequestVerificationToken: $("input[name='__RequestVerificationToken']").val(),
                    strPK: $("#edit-employee-id").val(),
                    // 直接取 select2 的 value (key)
                    str報工生產單位名稱: $("#edit-reporting-unit").val(),
                    str生產單位名稱: $("#edit-production-unit").val(),
                    str班別名稱: $("#edit-shift").val(),
                    str出勤類型: $("#edit-attendance-type").val(),
                    str作業人員工號: $("#edit-employee-no").val(),
                    str作業人員姓名: $("#edit-employee-name").val(),
                    str備註: $("#edit-remarks").val()
                };

                // 提交更新請求
                $.ajax({
                    url: '@Url.Action("UpdateEmployeeDetail", "ManpowerAllocation")',
                    type: 'POST',
                    data: formData,
                    success: function (response) {
                        if (response.success) {
                            Swal.fire({
                                icon: 'success',
                                title: '成功',
                                text: response.message,
                                confirmButtonText: '確定'
                            }).then((result) => {
                                // 返回人力配置首頁
                                window.location.href = '@Url.Action("Index", "ManpowerAllocation")';
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: '錯誤',
                                text: response.message,
                                confirmButtonText: '確定'
                            });
                        }
                    },
                    error: function (xhr, status, error) {
                        // 處理未授權/重定向
                        if (xhr.status === 401 || xhr.status === 302) {
                            Swal.fire({
                                icon: 'warning',
                                title: '登入過期',
                                text: '您的登入狀態已過期，請重新登入。',
                                confirmButtonText: '確定'
                            }).then(() => {
                                // 重定向到登入頁面
                                window.location.href = '@Url.Action("Login", "Home")?ReturnUrl=' + encodeURIComponent(window.location.href);
                            });
                            return;
                        }

                        // 處理禁止訪問
                        if (xhr.status === 403) {
                            Swal.fire({
                                icon: 'error',
                                title: '拒絕存取',
                                text: '您沒有權限執行此操作。',
                                confirmButtonText: '確定'
                            }).then(() => {
                                window.location.href = '@Url.Action("Index", "Home")';
                            });
                            return;
                        }

                        // 處理 JSON 回應中的授權錯誤
                        try {
                            var response = JSON.parse(xhr.responseText);
                            if (response && response.requireLogin) {
                                Swal.fire({
                                    icon: 'warning',
                                    title: '登入過期',
                                    text: response.message || '您的登入狀態已過期，請重新登入。',
                                    confirmButtonText: '確定'
                                }).then(() => {
                                    window.location.href = '@Url.Action("Login", "Home")?ReturnUrl=' + encodeURIComponent(window.location.href);
                                });
                                return;
                            }
                            if (response && response.unauthorized) {
                                Swal.fire({
                                    icon: 'error',
                                    title: '拒絕存取',
                                    text: response.message || '您沒有權限執行此操作。',
                                    confirmButtonText: '確定'
                                }).then(() => {
                                    window.location.href = '@Url.Action("Index", "Home")';
                                });
                                return;
                            }
                        } catch (e) {
                            // 解析 JSON 失敗，忽略
                        }

                        Swal.fire({
                            icon: 'error',
                            title: '錯誤',
                            text: "更新資料失敗：" + (xhr.responseJSON?.message || error),
                            confirmButtonText: '確定'
                        });
                    }
                });
            });

            // 取消按鈕點擊事件
            $("#cancel-button").click(function () {
                // 確認是否取消
                Swal.fire({
                    title: '確定要取消嗎？',
                    text: "您的修改將不會被儲存",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: '是，取消',
                    cancelButtonText: '否，繼續編輯'
                }).then((result) => {
                    if (result.isConfirmed) {

                         // 釋放鎖定
                         $.post('@Url.Action("ReleaseEmployeeDetailLock", "ManpowerAllocation")',
                             {
                                 id: $("#edit-employee-id").val(),
                                 __RequestVerificationToken: $("input[name='__RequestVerificationToken']").val()
                             }
                         ).always(function() {
                             // 無論成功失敗都返回
                             window.history.back();
                         });
                    }
                });
            });

            // 初始化下拉選單
            function initDropdowns() {
                // 初始化 Select2
                $("#edit-reporting-unit, #edit-production-unit, #edit-shift, #edit-attendance-type").select2({
                    placeholder: "請選擇...",
                    allowClear: true,
                    language: {
                        noResults: function () {
                            return "沒有符合的選項";
                        }
                    }
                });

                // 依據不同下拉選單，分別載入 key/value
                // 報工生產單位
                $.ajax({
                    url: '@Url.Action("Get報工生產單位List", "ManpowerAllocation")',
                    type: 'GET',
                    success: function (data) {
                        var $reportingUnitSelect = $("#edit-reporting-unit");
                        $reportingUnitSelect.empty();
                        $reportingUnitSelect.append('<option value="">請選擇...</option>');
                        $.each(data, function (i, item) {
                            $reportingUnitSelect.append('<option value="' + item.Guid + '">' + item.Name + '</option>');
                        });
                        setSelectValue('#edit-reporting-unit', '@Model.str報工生產單位GUID');
                    }
                });

                // 生產單位
                $.ajax({
                    url: '@Url.Action("GetProductionUnits", "ManpowerAllocation")',
                    type: 'GET',
                    success: function (data) {
                        var $productionUnitSelect = $("#edit-production-unit");
                        $productionUnitSelect.empty();
                        $productionUnitSelect.append('<option value="">請選擇...</option>');
                        $.each(data, function (i, item) {
                            $productionUnitSelect.append('<option value="' + item.Guid + '">' + item.Name + '</option>');
                        });
                        setSelectValue('#edit-production-unit', '@Model.str生產單位GUID');
                    }
                });

                // 班別
                $.ajax({
                    url: '@Url.Action("GetShifts", "ManpowerAllocation")',
                    type: 'GET',
                    success: function (data) {
                        var $shiftSelect = $("#edit-shift");
                        $shiftSelect.empty();
                        $shiftSelect.append('<option value="">請選擇...</option>');
                        $.each(data, function (i, item) {
                            $shiftSelect.append('<option value="' + item.Guid + '">' + item.Name + '</option>');
                        });
                        setSelectValue('#edit-shift', '@Model.str班別GUID');
                    }
                });

                // 出勤類型
                $.ajax({
                    url: '@Url.Action("GetAttendanceTypes", "ManpowerAllocation")',
                    type: 'GET',
                    success: function (data) {
                        var $attendanceTypeSelect = $("#edit-attendance-type");
                        $attendanceTypeSelect.empty();
                        $attendanceTypeSelect.append('<option value="">請選擇...</option>');
                        $.each(data, function (i, item) {
                            $attendanceTypeSelect.append('<option value="' + item.Guid + '">' + item.Name + '</option>');
                        });
                        setSelectValue('#edit-attendance-type', '@Model.str出勤GUID');
                    }
                });
            }

            // 設置下拉選單的值
            function setSelectValue(selector, value) {
                if (value) {
                    var $select = $(selector);

                    // 先嘗試使用直接的值
                    $select.val(value);

                    // 如果選不到，則添加選項並選中
                    if ($select.val() !== value) {
                        $select.append('<option value="' + value + '">' + value + '</option>');
                        $select.val(value);
                    }

                    // 後續需要觸發 select2 的更新
                    $select.trigger('change.select2');
                }
            }

            /*** 過滤下拉預設值 *********************************************************************/
            function getSelectValue(val) {
                return (val === "請選擇..." || val === null) ? "" : val;
            }
        });
    </script>

    @*/** Select2 **********************************************************************************************************/*@
    <link href="~/Content/select2/select2.min.css" rel="stylesheet" />
    <script src="~/Scripts/select2/select2.min.js"></script>

    <style>
        /* Select2 樣式調整 */
        /* 確保 Select2 容器佔用 100% 寬度 */
        .select2-container {
            width: 100% !important;
        }

            /* 針對 Select2 渲染後的單選框，也確保其寬度 */
            .select2-container .select2-selection--single {
                width: 100% !important;
                height: 33px !important;
            }

        /* input寬度100% */
        .col-md-4 .form-control {
            width: 100% !important;
            min-width: 0 !important;
            max-width: 100% !important;
            box-sizing: border-box !important;
            display: block !important;
        }

        .col-md-4 {
            padding-right: 15px;
            padding-left: 15px;
        }

        .form-group {
            margin-bottom: 15px;
        }
    </style>

}
