<script>
    $(document).ready(function () {
        // Data for the first pie chart
        var ctx1 = document.getElementById('myPieChart1').getContext('2d');
        var pieData1 = {
            labels: @Html.Raw(Json.Encode(Model.Select(m => m.CustNo).Distinct())),
            datasets: [{
                data: @Html.Raw(Json.Encode(Model.GroupBy(m => m.CustNo).Select(g => g.Sum(m => m.RequestCount)))),
                backgroundColor: [
                    'rgba(255, 99, 132, 0.2)',
                    'rgba(54, 162, 235, 0.2)',
                    'rgba(255, 206, 86, 0.2)',
                    'rgba(75, 192, 192, 0.2)',
                    'rgba(153, 102, 255, 0.2)',
                    'rgba(255, 159, 64, 0.2)'
                ],
                borderColor: [
                    'rgba(255, 99, 132, 1)',
                    'rgba(54, 162, 235, 1)',
                    'rgba(255, 206, 86, 1)',
                    'rgba(75, 192, 192, 1)',
                    'rgba(153, 102, 255, 1)',
                    'rgba(255, 159, 64, 1)'
                ],
                borderWidth: 1
            }]
        };

        var myPieChart1 = new Chart(ctx1, {
            type: 'pie',
            data: pieData1,
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'top',
                    },
                    tooltip: {
                        callbacks: {
                            label: function(tooltipItem) {
                                var label = pieData1.labels[tooltipItem.dataIndex];
                                var value = pieData1.datasets[0].data[tooltipItem.dataIndex];
                                var percentage = @Html.Raw(Json.Encode(Model.Select(m => m.RequestRatioPercentage)));
                                return label + ': ' + value + ' (' + percentage[tooltipItem.dataIndex] + ')';
                            }
                        }
                    },
                    datalabels: {
                        formatter: (value, context) => {
                            let label = context.chart.data.labels[context.dataIndex];
                            let percentage = @Html.Raw(Json.Encode(Model.Select(m => m.RequestRatioPercentage)));
                            return label + ': ' + value + ' (' + percentage[context.dataIndex] + ')';
                        }
                    }
                }
            },
            plugins: [ChartDataLabels] // 引入 ChartDataLabels 插件
        });

